{
  "name": "hello-llm-app",
  "version": "1.0.0",
  "description": "A TypeScript CLI and Web app with OpenAI-compatible LLM integration",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "npm -w packages/cli run dev --",
    "web": "npm -w packages/web run dev",
    "dev": "npm run web",
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "npm -w packages/cli run build",
    "build:web": "npm -w packages/web run build",
    "typecheck": "npm -w packages/cli run typecheck && npm -w packages/web run typecheck",
    "clean": "rm -rf packages/*/dist packages/*/.next packages/*/node_modules node_modules",
    "install:all": "npm install"
  },
  "keywords": [
    "cli",
    "web",
    "nextjs",
    "llm",
    "openai",
    "typescript",
    "ai",
    "chatgpt"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tardc/hello-llm-app.git"
  },
  "bugs": {
    "url": "https://github.com/tardc/hello-llm-app/issues"
  },
  "homepage": "https://github.com/tardc/hello-llm-app#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
